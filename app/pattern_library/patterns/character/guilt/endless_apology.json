{
  "pattern_key": "character.guilt.endless_apology",
  "version": 1,
  "family": "guilt",
  "scope": "character",
  "created_at": "2026-06-17",
  "updated_at": "2026-06-17",
  "trigger_fields": ["char_behavior", "char_lie"],
  "rules": [
    {
      "field": "char_behavior",
      "keywords": ["apologize", "sorry", "apologising", "excuse myself", "take up space", "shrink", "make themselves small", "over-explain", "justify everything"],
      "weight": 2.0
    },
    {
      "field": "char_lie",
      "keywords": ["my fault", "always wrong", "I cause problems", "burden", "too much", "inconvenience", "better without me around"],
      "weight": 1.5
    },
    {
      "field": "char_fear",
      "keywords": ["bother someone", "be too much", "take more than I give", "be resented"],
      "weight": 1.0
    }
  ],
