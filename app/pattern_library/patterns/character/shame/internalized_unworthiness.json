  "version": 1,
  "family": "shame",
  "scope": "character",
  "created_at": "2026-06-17",
  "updated_at": "2026-06-17",
  "trigger_fields": ["char_wound", "char_lie"],
  "rules": [
    {
      "field": "char_wound",
      "keywords": ["worthless", "unlovable", "nothing", "good for nothing", "told me I was", "made me feel like nothing", "treated as less than", "invisible", "discarded"],
      "weight": 2.0
    },
    {
      "field": "char_lie",
      "keywords": ["I am nothing", "unworthy", "not worthy", "don't deserve", "can't be loved", "too broken", "fundamentally wrong with me"],
      "weight": 1.5
    },
    {
      "field": "char_behavior",
      "keywords": ["accept less", "expect nothing", "settle", "don't ask for more", "grateful for scraps", "won't advocate for myself"],
      "weight": 1.0
    }
