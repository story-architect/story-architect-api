{
  "pattern_key": "character.belonging.belonging_through_conformity",
  "version": 1,
  "family": "belonging",
  "scope": "character",
  "created_at": "2026-06-17",
  "updated_at": "2026-06-17",
  "trigger_fields": ["char_lie", "char_behavior"],
  "rules": [
    {
      "field": "char_lie",
      "keywords": ["fit in", "be like them", "don't stand out", "blend", "go along", "keep the peace", "better to agree", "can't afford to be different"],
      "weight": 2.0
    },
    {
      "field": "char_behavior",
      "keywords": ["agree with everyone", "never disagree", "adapt to whoever", "change opinions to match", "mirror whoever they're with", "suppress real feelings", "stay quiet"],
      "weight": 1.5
    },
    {
      "field": "char_fear",
      "keywords": ["stand out", "be seen as difficult", "too much", "unwelcome", "lose the group", "alone if I'm honest"],
      "weight": 1.0
    }
  ],
